---
import Base from "./Base.astro";

interface Props {
  title?: string;
  frontmatter?: Record<string, any>;
}

const { title, frontmatter } = Astro.props;
---

<Base title={title} frontmatter={frontmatter}>
  <header
    class="sticky top-0 bg-black md:w-3/4 flex mx-auto px-4 py-2 justify-between text-white border-b border-white items-center"
  >
    <p class="font-bold">marko's site</p>
    <nav class="hidden md:flex gap-6">
      <a href="/" class="text-white hover:text-yellow">home</a>
      <a href="/bio" class="text-white hover:text-yellow">bio</a>
      <a href="/blog" class="text-white hover:text-yellow">blog</a>
      <a href="/projects" class="text-white hover:text-yellow">projects</a>
    </nav>
    <button
      class="bg-white hover:bg-orange rounded-xs sha py-1 px-2 text-black"
    >
      reach out!
    </button>
  </header>
  <main class="md:w-3/4 mx-auto px-4 py-2 text-white h-screen">
    <slot />
  </main>
</Base>

<footer></footer>
